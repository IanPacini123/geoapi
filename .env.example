# Banco de Dados (Configurações de Produção / Conexão externa)
# Descomente e preencha as variáveis abaixo quando for subir o sistema 
# utilizando um banco de dados externo (sem o profile 'dev' do Docker Compose)

# POSTGRES_USER=admin
# POSTGRES_PASSWORD=
# POSTGRES_DB=localidade
# POSTGRES_HOST=db
# POSTGRES_PORT=5432


# Cache
# REDIS_URL=redis://localhost:6379/0

# Segurança e CORS
# ALLOWED_ORIGINS=https://meudominio.com.br,https://app.meudominio.com.br
# WEB_CONCURRENCY=4

# Limites de Requisicao (Rate Limiting)
# RATE_LIMIT_GLOBAL=100/minute
# RATE_LIMIT_CEP=30/minute
# RATE_LIMIT_OPTIONS=300/minute
